generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  voices    Voice[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Voice {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  sourceType   String
  samples      Json
  profile      Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  generations  Generation[]
}

model Generation {
  id         String   @id @default(cuid())
  userId     String
  voiceId    String
  voice      Voice    @relation(fields: [voiceId], references: [id], onDelete: Cascade)
  userMsg    String
  draft      String
  reply      String
  draftModel String
  styleModel String
  createdAt  DateTime @default(now())
}
